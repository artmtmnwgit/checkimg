# CheckImg — один домен, без CORS.
# UI:  http://checkimg.play2go.cloud/
# API: http://checkimg.play2go.cloud/api/
#
# docker-compose: VITE_API_URL=  (пусто), VITE_PROXY_TARGET=http://api:8000
# .env: CORS_ORIGINS=*  (или не нужен при same-origin)

server {
    listen 80;
    server_name checkimg.play2go.cloud;

    client_max_body_size 20m;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
