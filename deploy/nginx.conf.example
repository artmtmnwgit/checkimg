# CheckImg — один домен на порту 80.
#
# Docker (рекомендуется на проде):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#   nginx слушает :80 → frontend:5173, /api/ → api:8000
#   Конфиг: deploy/nginx-docker.conf
#
# Или nginx на хосте (если без docker-nginx):
#   UI:  http://checkimg.play2go.cloud/
#   API: http://checkimg.play2go.cloud/api/
#   docker-compose.prod.yml: VITE_API_URL= (пусто)

server {
    listen 80;
    server_name checkimg.play2go.cloud;

    client_max_body_size 20m;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
